{
  "name": "wadrobe-top-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "setup": "npm run setup:client && npm run setup:server",
    "setup:client": "rm -rf wadrobe/wadrobe/client/node_modules && npm install --prefix wadrobe/wadrobe/client --legacy-peer-deps",
    "setup:server": "npm install --prefix wadrobe/wadrobe/server --legacy-peer-deps",
    "dev": "npm run dev --prefix wadrobe/wadrobe/client",
    "dev:server": "npm run dev --prefix wadrobe/wadrobe/server",
    "dev:all": "npx concurrently \"npm run dev --prefix wadrobe/wadrobe/client\" \"npm run dev --prefix wadrobe/wadrobe/server\"",
    "build": "npm run build --prefix wadrobe/wadrobe/client",
    "start": "npm run start --prefix wadrobe/wadrobe/client"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
